# Базовый путь на сервере (со слэшами в начале и конце).
# Корень сайта:
# VITE_BASE_PATH=/
#
# Подпапка, например https://site_name.ru/stepear/ :
VITE_BASE_PATH=/stepear/

# Информационные console.log (ноты при воспроизведении и др.)
# development: true, production: false (см. .env.development / .env.production)
# VITE_CONSOLE_LOG_INFO=true
